# Your Groq API key from console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Groq base URL (OpenAI-compatible endpoint)
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Model to use (llama-3.3-70b-versatile is Maverick)
DEFAULT_MODEL=llama-3.3-70b-versatile

# CORS settings
CORS_ALLOW_ORIGINS=*

# Database configuration
DATABASE_URL=sqlite:///./neuro_router.db

# JWT configuration
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Monthly token limit per user (0 disables limit)
MONTHLY_TOKEN_LIMIT=0

# Google OAuth
GOOGLE_CLIENT_ID=
