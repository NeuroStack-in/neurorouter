# Your Groq API key from console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# Groq base URL (OpenAI-compatible endpoint)
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Your custom API keys for clients (neurostack_XXXXXXXXXXXXX format)
# Add multiple keys separated by comma
VALID_API_KEYS=neurostack_a1b2c3d4e5f6g,neurostack_h7i8j9k0l1m2n

# Model to use (llama-3.3-70b-versatile is Maverick)
DEFAULT_MODEL=llama-3.3-70b-versatile

# CORS settings
CORS_ALLOW_ORIGINS=*
